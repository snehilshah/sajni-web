# Frontend (Vite) environment

# Base URL for the backend API.
#   - In dev, leave blank — the Vite proxy in vite.config.ts forwards /api
#     to http://localhost:8080.
#   - In production, leave blank when using the Vercel /api rewrite.
#     Set only if you intentionally want the browser to call a backend URL
#     directly instead of same-origin /api.
VITE_API_URL=
